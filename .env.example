# Tequila / Kiwi flight search API (free, no credit card)
# Sign up: https://tequila.kiwi.com/portal/register
# Then: API → My API keys → Create new key
TEQUILA_API_KEY=

# Amadeus flight search API (free test tier, real prices)
# Sign up: https://developers.amadeus.com → My Apps → Create new app
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Anthropic API key (optional — falls back to `claude -p` CLI if not set)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
